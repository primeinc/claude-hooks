{
  "rules": [
    {
      "id": "no-find",
      "description": "Use the Glob tool instead",
      "type": "banned-command",
      "commands": ["find"],
      "message": "{cmd} is banned. Use the Glob tool instead."
    },
    {
      "id": "no-grep",
      "description": "Use the Grep tool instead",
      "type": "banned-command",
      "commands": ["grep", "egrep", "fgrep"],
      "exempt_when": "rg.exe",
      "message": "{cmd} is banned. Use the Grep tool instead."
    },
    {
      "id": "no-truncation",
      "description": "Don't truncate output",
      "type": "banned-pipe-target",
      "commands": ["head", "tail", "less", "more"],
      "message": "Do not truncate output with {cmd}. Read the full output directly."
    },
    {
      "id": "no-test-pipe",
      "description": "Don't pipe test output",
      "type": "banned-pipe-source",
      "pattern": "test",
      "message": "Do not pipe test output. Run the test command directly and read the full output."
    },
    {
      "id": "no-package-runners",
      "description": "No arbitrary package execution",
      "type": "banned-command",
      "commands": ["npx", "bunx", "pnpx"],
      "message": "Package runners ({cmd}) are banned. Do not run arbitrary packages."
    },
    {
      "id": "no-package-runner-dlx",
      "description": "No dlx package execution",
      "type": "banned-subcommand",
      "commands": ["yarn", "pnpm"],
      "subcommands": ["dlx"],
      "message": "Package runners ({cmd} {sub}) are banned. Do not run arbitrary packages."
    },
    {
      "id": "no-package-runner-exec",
      "description": "No exec package execution",
      "type": "banned-subcommand",
      "commands": ["npm", "yarn", "pnpm"],
      "subcommands": ["exec"],
      "message": "Package runners ({cmd} {sub}) are banned. Do not run arbitrary packages."
    },
    {
      "id": "no-node-modules-bin",
      "description": "No direct node_modules/.bin/ execution",
      "type": "banned-path-pattern",
      "pattern": "node_modules/.bin/",
      "message": "Running binaries from node_modules/.bin/ directly is banned."
    },
    {
      "id": "no-test-runners",
      "description": "No direct test runner binaries",
      "type": "banned-command",
      "commands": ["vitest", "jest", "mocha", "pytest", "phpunit", "rspec"],
      "message": "Test runners ({cmd}) are banned. Do not run tests directly."
    },
    {
      "id": "no-lang-test",
      "description": "No language-native test commands",
      "type": "banned-subcommand",
      "commands": ["cargo", "go", "dotnet", "deno"],
      "subcommands": ["test"],
      "message": "Test runners ({cmd} {sub}) are banned. Do not run tests directly."
    },
    {
      "id": "no-node-test",
      "description": "No node --test",
      "type": "banned-flag",
      "commands": ["node"],
      "flags": ["--test"],
      "message": "Test runners (node --test) are banned. Do not run tests directly."
    },
    {
      "id": "no-pm-test",
      "description": "No PM test subcommands",
      "type": "banned-subcommand",
      "commands": ["npm", "yarn", "pnpm", "bun"],
      "subcommands": ["test"],
      "message": "Test runners ({cmd} {sub}) are banned. Do not run tests directly."
    },
    {
      "id": "no-pm-run-test",
      "description": "No PM run test",
      "type": "banned-subcommand-chain",
      "commands": ["npm", "yarn", "pnpm", "bun"],
      "chain": ["run", "test"],
      "message": "Test runners ({cmd} run test) are banned. Do not run tests directly."
    }
  ],
  "wrappers": ["bash", "sh", "zsh"]
}
