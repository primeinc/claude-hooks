{
  "rules": [
    {
      "id": "no-find",
      "description": "Use rg.exe instead",
      "type": "banned-command",
      "commands": ["find"],
      "message": "{cmd} is banned. Use rg.exe instead."
    },
    {
      "id": "no-grep",
      "description": "Use rg.exe instead",
      "type": "banned-command",
      "commands": ["grep", "egrep", "fgrep"],
      "exempt_when": "rg.exe",
      "message": "{cmd} is banned. Use rg.exe instead."
    },
    {
      "id": "no-truncation",
      "description": "Don't truncate output",
      "type": "banned-pipe-target",
      "commands": ["head", "tail", "less", "more"],
      "message": "Do not truncate output with {cmd}. Read the full output directly."
    },
    {
      "id": "no-test-pipe",
      "description": "Don't pipe test output",
      "type": "banned-pipe-source",
      "test_commands": ["vitest", "jest", "mocha", "pytest", "phpunit", "rspec"],
      "test_pm": ["npm", "yarn", "pnpm", "bun"],
      "test_lang": ["cargo", "go", "dotnet", "deno"],
      "message": "Do not pipe test output. Run the test command directly and read the full output."
    },
    {
      "id": "no-package-runners",
      "description": "No arbitrary package execution",
      "type": "banned-command",
      "commands": ["npx", "bunx", "pnpx"],
      "exempt_subcommands": ["skills"],
      "message": "Package runners ({cmd}) are banned. Do not run arbitrary packages."
    },
    {
      "id": "no-package-runner-dlx",
      "description": "No dlx package execution",
      "type": "banned-subcommand",
      "commands": ["yarn", "pnpm"],
      "subcommands": ["dlx"],
      "message": "Package runners ({cmd} {sub}) are banned. Do not run arbitrary packages."
    },
    {
      "id": "no-package-runner-exec",
      "description": "No exec package execution",
      "type": "banned-subcommand",
      "commands": ["npm", "yarn", "pnpm"],
      "subcommands": ["exec"],
      "message": "Package runners ({cmd} {sub}) are banned. Do not run arbitrary packages."
    },
    {
      "id": "no-node-modules-bin",
      "description": "No direct node_modules/.bin/ execution",
      "type": "banned-path-pattern",
      "pattern": "node_modules/.bin/",
      "message": "Do not run binaries from node_modules/.bin/ directly. Use npm scripts from package.json instead."
    },
    {
      "id": "no-test-tool-by-path",
      "description": "Run test/lint tools via package.json, not by path",
      "type": "banned-arg-pattern",
      "pattern": "node_modules/",
      "arg_must_also_match": ["eslint", "vitest", "jest", "mocha", "prettier", "tsc", "typescript", "biome", "oxlint", "pytest", "phpunit", "rspec"],
      "message": "Do not run test/lint tools from node_modules/ by path. Use npm scripts from package.json instead."
    }
  ],
  "wrappers": ["bash", "sh", "zsh"]
}
